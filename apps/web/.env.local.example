# ─── API ──────────────────────────────────────────────────────────────────────
# Demo mode: leave unset — the app uses its own built-in mock API (no backend needed).
# Production: set to the deployed NestJS URL.
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# ─── Supabase (required for auth) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Paystack (only needed for live payments, not required for demo) ───────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_key
